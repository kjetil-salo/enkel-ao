{
  "name": "fugle-e2e",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "test": "playwright test",
    "test:mock": "MOCK_PORT=3333 BASE_URL=http://localhost:3333 playwright test",
    "mock": "npx ts-node mock-server.ts",
    "test:with-mock": "npm run mock & sleep 2 && npm run test:mock; kill %1 2>/dev/null || true"
  },
  "devDependencies": {
    "@playwright/test": "^1.39.0",
    "@types/node": "^20.10.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2"
  }
}
